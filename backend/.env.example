# Copier ce fichier en .env et remplir les vraies valeurs (ne jamais commiter .env)

# URL de connexion PostgreSQL fournie par Supabase
# Format: postgresql://postgres:[MOT_DE_PASSE]@[HOST]:5432/postgres
DATABASE_URL=postgresql://postgres:password@localhost:5432/comafrique_planning

# Clé secrète pour signer les tokens JWT (générer une chaîne aléatoire longue)
# Exemple de génération: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_moi_avec_une_cle_aleatoire_longue

# Algorithme de signature JWT
ALGORITHM=HS256

# Durée de validité du token en minutes (480 = 8h, une journée de travail)
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Origines autorisées pour le CORS (URL du frontend Vercel + localhost pour le dev)
CORS_ORIGINS=http://localhost:3000,https://comafrique-planning.vercel.app
